<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0-windows;net472</TargetFrameworks>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageId>MarkdownWPF</PackageId>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <Description>High-performance, true UI-virtualized Markdown renderer for WPF based on Markdig. Renders Markdown into lightweight WPF blocks inside a VirtualizingStackPanel for smooth scrolling on large documents. Includes a flexible XAML styling system (base + override styles), theming support, and memory-aware image decoding.</Description>
    <PackageReleaseNotes>
      Registered HtmlInlineRenderer and HtmlBlockRenderer in ObjectRenderers.
      Added basic infrastructure for HTML nodes without full tag rendering support (raw content only).
    </PackageReleaseNotes>
  </PropertyGroup>

  <ItemGroup>
    <None Include="$(MSBuildThisFileDirectory)..\..\README.md">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Markdig" />
  </ItemGroup>

</Project>
